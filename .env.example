# Follow Up Boss API key (owner-level, used as HTTP Basic Auth username)
FUB_API_KEY=

# Anthropic API key for Claude-powered insights
ANTHROPIC_API_KEY=

# Dashboard login password (plaintext — hashed on startup with bcrypt)
DASHBOARD_PASSWORD=

# Session secret for express-session cookie signing
SESSION_SECRET=

# API key to protect /api/refresh endpoint from unauthorized triggers
DASHBOARD_API_KEY=
